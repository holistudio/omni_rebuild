# =============================================================================
# Project Omnibot — .gitignore
# Stack: Python/Flask, Conda, LangGraph, TypeScript, esbuild, WSL2
# =============================================================================
 
# --- Secrets & Environment ---
.env
.env.*
!.env.example
 
# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.manifest
*.spec
 
# --- Conda / Virtual Environments ---
# Don't commit the env itself — use requirements.txt to reproduce it
/env/
/venv/
/.venv/
# If someone runs `conda env export > environment.yml` locally, don't commit it
# unless you intentionally want to pin the full env
environment.yml
 
# --- Flask ---
instance/
.webassets-cache
flask_session/
 
# --- LangGraph / LangChain ---
# Checkpoint databases if using SQLite persistence
*.db
*.sqlite
*.sqlite3
langgraph.json
 
# --- Runtime Data (JSON file storage) ---
# These are ephemeral session artifacts, not source code
backend/data/conversations/
backend/data/search_results/
backend/data/recommendations/
 
# --- Node / Frontend ---
node_modules/
frontend/dist/
frontend/.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
 
# --- TypeScript ---
*.js.map
*.tsbuildinfo
 
# --- esbuild ---
# dist/ is already covered above; explicitly ignore any esbuild metafiles
*.esbuild-meta.json
 
# --- Editors & IDEs ---
.vscode/
!.vscode/extensions.json   # OK to share recommended extensions
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
 
# --- WSL2 / OS ---
.directory
desktop.ini
 
# --- Logs ---
*.log
logs/
 
# --- draw.io ---
*.bkp
/backend/data

        <mxCell id="lJY5epmsm3EuKLIO2xQp-31" value="Book Recommendations&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Title&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Author&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Year&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Genre&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Summary&lt;/span&gt;&lt;br&gt;**Explanation**" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;verticalAlign=top;fontStyle=1" parent="1" vertex="1">

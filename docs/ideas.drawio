<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/26.2.15 Chrome/134.0.6998.205 Electron/35.2.1 Safari/537.36" version="26.2.15" pages="5">
  <diagram id="dpnnAuReYeWUSulbxY7R" name="ux-frontend">
    <mxGraphModel dx="5748" dy="2394" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="PmzNDFpxscOfxV4MDq_8-10" value="" style="rounded=0;whiteSpace=wrap;html=1;fontSize=72;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="280" y="900" width="1040" height="900" as="geometry" />
        </mxCell>
        <mxCell id="PmzNDFpxscOfxV4MDq_8-1" value="&lt;h1&gt;User Story&lt;/h1&gt;&lt;p&gt;&lt;b&gt;1. Chat Page: &lt;/b&gt;Omnibot starts a coversation with the user about books and their specific tastes.&lt;/p&gt;&lt;p&gt;2. Chat Page: After about 10 questions, Omnibot summarizes back to the user their tastes to confirm understanding. (If the user expresses refinements or dissatisfaction, Omnibot asks 3 more questions, then proceeds to next step)&lt;/p&gt;&lt;p&gt;3. Chat Page: Omnibot then says &quot;OK, let me search through books...&quot;&lt;/p&gt;&lt;p&gt;&lt;b&gt;4. Recommendation Page: &lt;/b&gt;List of book title, author, year, genre, summary, and Omnibot specific explanation, citing moments from the conversation to justify.&lt;/p&gt;&lt;p&gt;&lt;i&gt;5. Recommendation Page: User can continue the conversation with Omnibot to refine the recommendations.&lt;/i&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="280" height="350" as="geometry" />
        </mxCell>
        <mxCell id="PmzNDFpxscOfxV4MDq_8-2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
          <mxGeometry width="10" height="10" as="geometry" />
        </mxCell>
        <mxCell id="PmzNDFpxscOfxV4MDq_8-4" value="&lt;h1&gt;Chat Page: 1&lt;/h1&gt;&lt;p&gt;Make the chat front and center&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry y="960" width="190" height="120" as="geometry" />

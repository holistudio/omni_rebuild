        <mxCell id="lJY5epmsm3EuKLIO2xQp-36" value="&lt;h1&gt;Step 1: Chat&lt;/h1&gt;&lt;p&gt;Omnibot starts a coversation with the user about books and their specific tastes and builds up a conversation history&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="-370" y="-90" width="190" height="120" as="geometry" />
        </mxCell>
        <mxCell id="GWtzCWjQPLFzB_lwqaIf-3" value="&lt;h1&gt;Step 2: Search&lt;/h1&gt;&lt;p&gt;Agent constructs a search query of a book-related API. The Agent is ulimately looking for at least 5 books that it assesses are a good fit for the user (i.e., if the API doesn&#39;t return 5 results, the agent attempts different search queries until this quota is reached)&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="-250" y="330" width="190" height="190" as="geometry" />
        </mxCell>
        <mxCell id="GWtzCWjQPLFzB_lwqaIf-4" value="&lt;h1&gt;Step 3: Recommend&lt;/h1&gt;&lt;p&gt;Given the context of these search results and the user conversation, the Agent then returns five book recommendations. Each recommended book is displayed with the Agent&#39;s explanation based on the user&#39;s conversation history.&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="-250" y="660" width="191" height="226" as="geometry" />
        </mxCell>
        <mxCell id="GWtzCWjQPLFzB_lwqaIf-7" value="Final Search Results&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;Title&lt;br&gt;Author&lt;br&gt;Year&lt;br&gt;Genre&lt;br&gt;Summary&lt;br&gt;&lt;br&gt;&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;verticalAlign=top;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="400" y="755" width="120" height="130" as="geometry" />
